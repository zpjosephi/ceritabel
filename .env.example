# --- AI providers (server-side only; do NOT prefix with NEXT_PUBLIC_) ---

# Google Gemini — free, no credit card: https://aistudio.google.com
GEMINI_API_KEY=

# Groq (Llama models) — free, no credit card: https://console.groq.com/keys
# Optional: only needed if you want the Groq models in the model picker.
GROQ_API_KEY=

# Discord webhook URL for in-app feedback (server-side only). Optional.
DISCORD_WEBHOOK_URL=
